# ─── GitHub OAuth App ────────────────────────────────────────────
# Create at: https://github.com/settings/developers → "New OAuth App"
# Homepage URL:            http://YOUR_SERVER_IP
# Authorization callback: http://YOUR_SERVER_IP/auth/callback

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ─── Webhook Secret ──────────────────────────────────────────────
# Any random string — used to verify payloads from GitHub
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ─── App Secret ──────────────────────────────────────────────────
# Used to sign JWT tokens — keep this private
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# ─── Frontend URL ────────────────────────────────────────────────
# The public URL of your deployment (used for OAuth redirect + webhook URL)
FRONTEND_URL=http://localhost

# ─── Database ────────────────────────────────────────────────────
# SQLite path inside the container (persisted via Docker volume)
DATABASE_URL=sqlite+aiosqlite:////app/data/codeguard.db

# ─── Module 2: Upload Analyser (AWS) ─────────────────────────────
# S3 bucket for storing analysis results (leave blank to disable)
# Create with: aws s3 mb s3://codeguard-results-dev --region us-east-1
UPLOAD_RESULTS_BUCKET=

# AWS region (used by boto3 for S3 + CloudWatch)
AWS_REGION=us-east-1

# CloudWatch custom metrics namespace
CW_NAMESPACE=CodeGuard

# AWS credentials — use IAM instance profile on EC2 (preferred)
# or set these for local development only (never commit to git)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
